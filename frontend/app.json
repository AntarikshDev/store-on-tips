{
  "expo": {
    "name": "Pictocart Seller",
    "slug": "pictocart-seller",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pictocart",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.pictocart.merchant",
      "associatedDomains": ["applinks:pictocart.in"],
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of products to add to your store.",
        "NSPhotoLibraryUsageDescription": "Pick product photos from your gallery.",
        "NSPhotoLibraryAddUsageDescription": "Save invoices and shared images to your gallery.",
        "NSLocationWhenInUseUsageDescription": "Auto-fill your store and pickup address.",
        "NSFaceIDUsageDescription": "Use Face ID for fast, secure sign-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "edgeToEdgeEnabled": true,
      "package": "app.pictocart.merchant",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "pictocart.in" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Take photos of products to add to your store.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick product photos from your gallery.",
          "cameraPermission": "Take photos of products to add to your store."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID for fast, secure sign-in."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Auto-fill your store and pickup address."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#F97316"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
